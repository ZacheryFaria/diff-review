{
  "name": "diff-review",
  "version": "0.1.0",
  "description": "Local git diff viewer with inline commenting for Claude code review",
  "type": "module",
  "bin": {
    "diff-review": "./bin/diff-review.js"
  },
  "scripts": {
    "dev": "concurrently \"tsx watch server/dev.ts\" \"vite\"",
    "build": "pnpm run generate-types && tsc -p tsconfig.server.json && vite build && cp schema.json dist/",
    "generate-types": "json2ts schema.json > src/types/schema.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "picomatch": "^4.0.4",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.8",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/yargs": "^17.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "react": "^18.3.0",
    "react-diff-view": "^3.3.0",
    "react-dom": "^18.3.0",
    "refractor": "^3.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "bin/",
    "dist/",
    "schema.json"
  ]
}
